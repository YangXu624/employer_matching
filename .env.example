# Copy this file to .env and fill in your keys. Never commit .env.
# Get a free Gemini key: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your-key-here

# Optional. Defaults to gemini-2.5-flash.
GEMINI_MODEL=gemini-2.5-flash

# Passport agent uses GEMINI_API_KEY; backend maps GOOGLE_API_KEY if unset.
# GEMINI_API_KEY=your-key-here

# Supabase (Dashboard → Project Settings → API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional. Folder containing seeker_entry.py (default: passport_agent/)
# PASSPORT_AGENT_ROOT=passport_agent
