# Copy this file to `.env` and fill in real values. Never commit `.env`.

# --- Required for "LLM Check" (Gemini scoring) ---
# Get a key from https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional alias (some tools read this instead)
GOOGLE_API_KEY=your_gemini_api_key_here

# Optional. LLM scorer uses gemini-2.5-flash by default.
GEMINI_MODEL=gemini-2.5-flash

# --- JD storage layer ---
# Which job store the backend uses. SQLite is the main/default store; leave
# unset (or set "sqlite") for local file storage. Set "supabase" to opt in to
# the cloud store, which also requires the Supabase credentials below.
JOB_STORE=sqlite

# Supabase project (backend only — these never reach the browser).
# Only needed when JOB_STORE=supabase. The service role key bypasses RLS,
# so keep it server-side.
# SUPABASE_URL=https://your-project-ref.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
# Anon key is not used by the backend job store; kept for reference only.
# SUPABASE_ANON_KEY=your_supabase_anon_key
